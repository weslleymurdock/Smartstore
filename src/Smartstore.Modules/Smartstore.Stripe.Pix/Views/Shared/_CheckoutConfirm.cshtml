@model StripePixCheckoutState
<h1> CHECKOUT STATE VIEW </h1>
<script data-origin="stripe-pix-confirm">
    var isConfirmed = @(Model.IsConfirmed.ToString().ToLower());
    
    $(function () {
        // Escuta o evento de submissão do pedido do Smartstore
        $(document).on('submitOrder', function (e) {
            // Se já confirmamos e o Stripe processou, liberamos o fluxo padrão
            if (isConfirmed) {
                return;
            }

            // Caso contrário, interceptamos para processar o PIX primeiro
            e.isOrderValid = false; 
            var data = $('#confirm-order-form').serializeArray();

            // Desativa o botão de compra para evitar cliques duplos
            $(document).trigger({ type: 'disableBuyButton', disable: true });

            $.ajax({
                type: 'POST',
                url: '@Url.Action("ConfirmOrder", "StripePix")', // Aponta para o SEU controller
                data: { "formData": JSON.stringify(data) },
                success: function (response) {
                    if (response.success) {
                        if (response.redirectUrl) {
                            // REDIRECIONAMENTO: Aqui ele vai para a sua Action DisplayQrCode
                            window.location.href = response.redirectUrl;
                        } else {
                            // Caso não precise de redirecionamento, confirma e clica no botão original
                            isConfirmed = true;
                            triggerBuyButton(false);
                        }
                    }
                    else if (response.messages && response.messages.length > 0) {
                        reportError(response.messages);
                        $(document).trigger({ type: 'disableBuyButton', disable: false });
                    }
                },
                error: function (objXml) {
                    var msg = objXml?.responseText || "Erro ao processar PIX";
                    reportError(msg);
                    $(document).trigger({ type: 'disableBuyButton', disable: false });
                }
            });
        });

        // Se o Webhook ou RedirectionResult marcou para submeter automaticamente
        @if (Model.SubmitForm)
        {
            <text>
            $(function () {
                triggerBuyButton(true);
            });
            </text>
        }

        function triggerBuyButton(showThrobber) {
            var clickBuyButtonEvent = $.Event('clickBuyButton');
            clickBuyButtonEvent.customerAgreed = true;
            clickBuyButtonEvent.showThrobber = showThrobber;
            $(document).trigger(clickBuyButtonEvent);
        }

        function reportError(message) {
            var errorEvent = jQuery.Event('reportError');
            errorEvent.message = message;
            $(document).trigger(errorEvent);
        }
    });
</script>